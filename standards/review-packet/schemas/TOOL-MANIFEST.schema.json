{
  "$id": "https://ai-tools.local/schemas/review-packet/TOOL-MANIFEST.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Tool and run metadata for review packets. Mirrors ai-workspace-kit concepts without adopting its adapter manifest.",
  "properties": {
    "generated_files": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "path": {
            "minLength": 1,
            "type": "string"
          },
          "sha256": {
            "pattern": "^[a-f0-9]{64}$",
            "type": "string"
          }
        },
        "required": [
          "path"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "input": {
      "additionalProperties": false,
      "properties": {
        "args": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "target_path": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "target_path"
      ],
      "type": "object"
    },
    "policy_hashes": {
      "additionalProperties": {
        "pattern": "^[a-f0-9]{64}$",
        "type": "string"
      },
      "description": "Hashes for safety, ignore, evidence, or permission policies used by the tool run.",
      "type": "object"
    },
    "read_write_behavior": {
      "enum": [
        "read_only",
        "review_output_only",
        "mutation_capable"
      ]
    },
    "requested_outputs": {
      "items": {
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "run_timestamp": {
      "format": "date-time",
      "type": "string"
    },
    "safety_profile": {
      "additionalProperties": false,
      "properties": {
        "review_only": {
          "type": "boolean"
        },
        "secret_policy": {
          "minLength": 1,
          "type": "string"
        },
        "target_mutation": {
          "enum": [
            "none",
            "explicit_fix_mode",
            "unknown"
          ]
        }
      },
      "required": [
        "review_only",
        "target_mutation",
        "secret_policy"
      ],
      "type": "object"
    },
    "schema_versions": {
      "additionalProperties": {
        "type": "string"
      },
      "type": "object"
    },
    "source_commit": {
      "type": [
        "string",
        "null"
      ]
    },
    "target_project": {
      "additionalProperties": false,
      "properties": {
        "display_name": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      },
      "required": [
        "path"
      ],
      "type": "object"
    },
    "tool_name": {
      "minLength": 1,
      "type": "string"
    },
    "tool_version": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "tool_name",
    "tool_version",
    "schema_versions",
    "input",
    "generated_files",
    "run_timestamp",
    "safety_profile",
    "policy_hashes"
  ],
  "title": "Review Packet Tool Manifest",
  "type": "object"
}
